<?xml version="1.0" encoding="utf-8"?>
<!-- Off-screen WebView2 "camera": full-resolution playback that WGC captures. Borderless, kept mapped
     (never hidden/minimized), positioned off-screen. The user never interacts with it. -->
<Window
    x:Class="YtRec.App.PlayerWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Grid Background="Black">
        <WebView2 x:Name="Web"/>
    </Grid>
</Window>
