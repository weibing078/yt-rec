<?xml version="1.0" encoding="utf-8"?>
<!-- CIS brand tokens (see mac BrandColor.swift / branding/CIS-YTRec.md).
     Signal red = record / primary / progress; Crimson = stop / destructive.
     Chrome uses system theme; brand color only accents. -->
<ResourceDictionary
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <ResourceDictionary.ThemeDictionaries>

        <ResourceDictionary x:Key="Dark">
            <Color x:Key="BrandSignalColor">#FF2E45</Color>
            <Color x:Key="BrandSignalLightColor">#FF3D52</Color>
            <Color x:Key="BrandCrimsonColor">#D5002A</Color>
            <Color x:Key="BrandIdleColor">#8A8F98</Color>

            <SolidColorBrush x:Key="BrandSignalBrush" Color="#FF2E45" />
            <SolidColorBrush x:Key="BrandSignalHoverBrush" Color="#FF3D52" />
            <SolidColorBrush x:Key="BrandSignalSoftBrush" Color="#FF2E45" Opacity="0.14" />
            <SolidColorBrush x:Key="BrandIdleBrush" Color="#8A8F98" />
            <!-- status text colors tuned for AA on dark surfaces -->
            <SolidColorBrush x:Key="BrandDangerTextBrush" Color="#FF6373" />
            <SolidColorBrush x:Key="BrandSuccessTextBrush" Color="#34C88E" />
            <SolidColorBrush x:Key="BrandWarningTextBrush" Color="#F5A623" />
            <SolidColorBrush x:Key="BrandDownloadBrush" Color="#6FA8E0" />
        </ResourceDictionary>

        <ResourceDictionary x:Key="Light">
            <Color x:Key="BrandSignalColor">#FF2E45</Color>
            <Color x:Key="BrandSignalLightColor">#FF3D52</Color>
            <Color x:Key="BrandCrimsonColor">#D5002A</Color>
            <Color x:Key="BrandIdleColor">#8A8F98</Color>

            <SolidColorBrush x:Key="BrandSignalBrush" Color="#FF2E45" />
            <SolidColorBrush x:Key="BrandSignalHoverBrush" Color="#FF3D52" />
            <SolidColorBrush x:Key="BrandSignalSoftBrush" Color="#FF2E45" Opacity="0.12" />
            <SolidColorBrush x:Key="BrandIdleBrush" Color="#8A8F98" />
            <!-- status text colors tuned for AA on light surfaces -->
            <SolidColorBrush x:Key="BrandDangerTextBrush" Color="#D5002A" />
            <SolidColorBrush x:Key="BrandSuccessTextBrush" Color="#0F6E56" />
            <SolidColorBrush x:Key="BrandWarningTextBrush" Color="#8A5A00" />
            <SolidColorBrush x:Key="BrandDownloadBrush" Color="#185FA5" />
        </ResourceDictionary>

    </ResourceDictionary.ThemeDictionaries>

</ResourceDictionary>
