# ── Build outputs ───────────────────────────────────────────────
# Swift (mac)
.build/
**/.build/
mac/dist/

# .NET / WinUI (windows)
windows/**/bin/
windows/**/obj/
windows/**/*.user
.vs/
# packaged Windows installer (built by windows/installer/build-installer.ps1, uploaded to Releases)
windows/dist/

# ── Vendored binaries (fetched by tools/setup-binaries.*) ────────
# yt-dlp / ffmpeg are downloaded locally, never committed.
**/Vendor/bin/
**/vendor/bin/

# ── OS / editor cruft ────────────────────────────────────────────
.DS_Store
*.o
*.d
.idea/
*.swp

# ── Tool / test session artifacts ────────────────────────────────
.playwright-mcp/

# Local editor / tooling state (not for the repo)
.claude/
.wrangler/
